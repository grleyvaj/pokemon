	"item": [
		{
			"name": "Fetch ID",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const responseXml = pm.response.text();",
							"",
							"// Validar código HTTP",
							"pm.test(\"Código de respuesta es 200\", function() {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"// Extraer el valor de <id> usando regex",
							"const idMatch = responseXml.match(/<id>(\\d+)<\\/id>/);",
							"const idValue = idMatch ? idMatch[1] : null;",
							"",
							"// Validaciones",
							"pm.test(\"Campo id existe\", function() {",
							"    pm.expect(idValue).to.not.be.null;",
							"});",
							"",
							"pm.test(\"Campo id tiene valor numérico\", function() {",
							"    pm.expect(Number(idValue)).to.be.a(\"number\");",
							"});",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const pokemons = [",
							"  \"bulbasaur\",\"ivysaur\",\"venusaur\",\"charmander\",\"charmeleon\",\"charizard\",",
							"  \"squirtle\",\"wartortle\",\"blastoise\",\"caterpie\",\"metapod\",\"butterfree\",",
							"  \"weedle\",\"kakuna\",\"beedrill\",\"pidgey\",\"pidgeotto\",\"pidgeot\",",
							"  \"rattata\",\"raticate\",\"pikachu\",\"raichu\",\"sandshrew\",\"sandslash\",",
							"  \"clefairy\",\"vulpix\",\"jigglypuff\",\"zubat\",\"oddish\",\"gloom\",\"vileplume\"",
							"];",
							"",
							"const choice = pokemons[Math.floor(Math.random() * pokemons.length)];",
							"pm.variables.set(\"POKEMON_NAME\", choice);",
							"console.log(\"POKEMON_NAME =\", choice);",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "text/xml;charset=UTF-8",
						"type": "text"
					},
					{
						"key": "SOAPAction",
						"value": "IdRequestSoap",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\"\n                  xmlns:pok=\"http://pokemon.demo.mx/\">\n    <soapenv:Header/>\n    <soapenv:Body>\n        <pok:IdRequestSoap>\n            <pok:name>{{POKEMON_NAME}}</pok:name>\n        </pok:IdRequestSoap>\n    </soapenv:Body>\n</soapenv:Envelope> \n",
					"options": {
						"raw": {
							"language": "xml"
						}
					}
				},
				"url": {
					"raw": "{{local-pokemon-url}}/ws",
					"host": [
