		{
			"name": "Fetch Held Items",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Held items structure is correct if present\", function () {",
							"    const jsonObj = xml2Json(pm.response.text());",
							"    ",
							"    const heldItemsResponse = jsonObj['SOAP-ENV:Envelope']['SOAP-ENV:Body']['ns3:HeldItemListResponseSoap']['held_items'];",
							"    ",
							"    // Si no hay elementos, termina el test sin errores",
							"    if (!heldItemsResponse) {",
							"        pm.expect(heldItemsResponse).to.be.oneOf([null, undefined]);",
							"        return;",
							"    }",
							"    ",
							"    // Si hay elementos, fuerza que sea array",
							"    const heldItemsArray = Array.isArray(heldItemsResponse) ? heldItemsResponse : [heldItemsResponse];",
							"    ",
							"    heldItemsArray.forEach(heldItem => {",
							"        // Debe tener nodo item",
							"        pm.expect(heldItem['item']).to.exist;",
							"        pm.expect(heldItem['item']['name']).to.exist;",
							"        pm.expect(heldItem['item']['url']).to.exist;",
							"",
							"        // Debe tener al menos un version_details",
							"        const versionDetails = heldItem['version_details'];",
							"        pm.expect(versionDetails).to.exist;",
							"",
							"        const versionDetailsArray = Array.isArray(versionDetails) ? versionDetails : [versionDetails];",
							"",
							"        versionDetailsArray.forEach(detail => {",
							"            pm.expect(detail['version']).to.exist;",
							"            pm.expect(detail['version']['name']).to.exist;",
							"            pm.expect(detail['version']['url']).to.exist;",
							"            pm.expect(detail['rarity']).to.exist;",
							"        });",
							"    });",
							"});",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
