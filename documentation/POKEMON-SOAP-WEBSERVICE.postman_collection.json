		{
			"name": "Fetch Abbility",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response contiene listado de abilities con los campos requeridos\", function () {",
							"    // Convertir XML -> JSON",
							"    const jsonData = xml2Json(pm.response.text());",
							"",
							"    const abilities = jsonData['SOAP-ENV:Envelope']",
							"        ['SOAP-ENV:Body']",
							"        ['ns3:AbilityListResponseSoap']",
							"        ['ability'];",
							"",
							"    const list = Array.isArray(abilities) ? abilities : [abilities];",
							"",
							"    pm.expect(list.length).to.be.greaterThan(0);",
							"",
							"    list.forEach((ability, idx) => {",
							"        pm.expect(ability).to.have.property(\"hidden\");",
							"        pm.expect(ability).to.have.property(\"slot\");",
							"        pm.expect(ability).to.have.property(\"resource\");",
							"        pm.expect(ability.resource).to.have.property(\"name\");",
							"        pm.expect(ability.resource).to.have.property(\"url\");",
							"    });",
							"});",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const pokemons = [",
